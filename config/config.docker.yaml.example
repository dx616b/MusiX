# Copy to config.docker.yaml for Docker (gitignored).
# Point at your existing Prowlarr, Jackett, and Transmission instances.
server:
  host: "0.0.0.0"
  port: 8080

prowlarr:
  url: "http://host.docker.internal:9696"
  apiKey: "YOUR_PROWLARR_API_KEY"

jackett:
  url: "http://host.docker.internal:9117"
  apiKey: "YOUR_JACKETT_API_KEY"

transmission:
  url: "http://host.docker.internal:9091/transmission/rpc"
  username: ""
  password: ""

store:
  sqlitePath: "/app/data/musicx.db"
