# Copy to .env — optional secret overrides for docker compose.
# Service URLs live in config/config.docker.yaml (or the Settings UI).
LOG_LEVEL=info
PROWLARR_API_KEY=
# Optional comma-separated categories for Prowlarr (e.g. 3000,3010,3040); empty = all categories
PROWLARR_MUSIC_CATEGORIES=
JACKETT_API_KEY=
# Optional comma-separated Torznab categories (e.g. 3000,3010,3040); empty = all categories
JACKETT_MUSIC_CATEGORIES=
TRANSMISSION_USER=
TRANSMISSION_PASS=
# In-memory torrent preview/stream sessions (per info hash)
TORRENT_SESSION_MAX=2
TORRENT_SESSION_LEAK_TTL_MINUTES=5
